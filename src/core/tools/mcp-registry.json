		{
			"name": "filesystem",
			"package": "@modelcontextprotocol/server-filesystem",
			"install": "npx -y @modelcontextprotocol/server-filesystem <allowed-paths>",
			"description": "Read/write files in specified directories with sandboxed permissions",
			"capabilities": [
				"read_file",
				"write_file",
				"list_directory",
				"create_directory",
				"move_file"
			],
			"trigger_keywords": [
				"files",
				"directory",
				"filesystem",
				"read files"
			]
		},
